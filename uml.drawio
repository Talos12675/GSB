    <diagram id="QlrHJA6btvfNHXgZodtR" name="Page-1">
        <mxGraphModel dx="3410" dy="4197" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    direction LR\n\n    class activite_compl {\n        AC_NUM int\n        AC_DATE datetime\n        AC_LIEU varchar(25)\n        AC_THEME varchar(10)\n        AC_MOTIF varchar(50)\n    }\n\n    class inviter {\n        AC_NUM int\n        PRA_NUM smallint\n        SPECIALISTEON bit(1)\n    }\n\n    class realiser {\n        AC_NUM int\n        VIS_MATRICULE varchar(10)\n        REA_MTTFRAIS float\n    }\n\n    class rapport_visite {\n        VIS_MATRICULE varchar(10)\n        RAP_NUM int\n        PRA_NUM smallint\n        RAP_DATE datetime\n        RAP_BILAN varchar(255)\n        RAP_MOTIF varchar(255)\n    }\n\n    class offrir {\n        VIS_MATRICULE varchar(10)\n        RAP_NUM int\n        MED_DEPOTLEGAL varchar(10)\n        OFF_QTE smallint\n    }\n\n    class praticien {\n        PRA_NUM smallint\n        PRA_NOM varchar(25)\n        PRA_PRENOM varchar(30)\n        PRA_ADRESSE varchar(50)\n        PRA_CP varchar(5)\n        PRA_VILLE varchar(25)\n        PRA_COEFNOTORIETE float\n        TYP_CODE varchar(3)\n    }\n\n    class type_praticien {\n        TYP_CODE varchar(3)\n        TYP_LIBELLE varchar(25)\n        TYP_LIEU varchar(35)\n    }\n\n    class visiteur {\n        VIS_MATRICULE varchar(10)\n        VIS_NOM varchar(25)\n        Vis_PRENOM varchar(50)\n        VIS_ADRESSE varchar(50)\n        VIS_CP varchar(5)\n        VIS_VILLE varchar(30)\n        VIS_DATEEMBAUCHE datetime\n        SEC_CODE varchar(1)\n        LAB_CODE varchar(2)\n    }\n\n    class labo {\n        LAB_CODE varchar(2)\n        LAB_NOM varchar(10)\n        LAB_CHEFVENTE varchar(20)\n    }\n\n    class secteur {\n        SEC_CODE varchar(1)\n        SEC_LIBELLE varchar(15)\n    }\n\n    class region {\n        REG_CODE varchar(2)\n        SEC_CODE varchar(1)\n        REG_NOM varchar(50)\n    }\n\n    class travailler {\n        VIS_MATRICULE varchar(10)\n        JJMMAA datetime\n        REG_CODE varchar(2)\n        TRA_ROLE varchar(11)\n    }\n\n    class medicament {\n        MED_DEPOTLEGAL varchar(10)\n        MED_NOMCOMMERCIAL varchar(25)\n        FAM_CODE varchar(3)\n        MED_COMPOSITION varchar(255)\n        MED_EFFETS varchar(255)\n        MED_CONTREINDIC varchar(255)\n        MED_PRIXECHANTILLON float\n    }\n\n    class famille {\n        FAM_CODE varchar(3)\n        FAM_LIBELLE varchar(80)\n    }\n\n    class constituer {\n        MED_DEPOTLEGAL varchar(10)\n        CMP_CODE varchar(4)\n        CST_QTE float\n    }\n\n    class composant {\n        CMP_CODE varchar(4)\n        CMP_LIBELLE varchar(25)\n    }\n\n    class prescrire {\n        MED_DEPOTLEGAL varchar(10)\n        TIN_CODE varchar(5)\n        DOS_CODE varchar(10)\n        PRE_POSOLOGIE varchar(40)\n    }\n\n    class type_individu {\n        TIN_CODE varchar(5)\n        TIN_LIBELLE varchar(50)\n    }\n\n    class dosage {\n        DOS_CODE varchar(10)\n        DOS_QUANTITE varchar(10)\n        DOS_UNITE varchar(10)\n    }\n\n    class formuler {\n        MED_DEPOTLEGAL varchar(10)\n        PRE_CODE varchar(2)\n    }\n\n    class presentation {\n        PRE_CODE varchar(2)\n        PRE_LIBELLE varchar(20)\n    }\n\n    class interagir {\n        MED_PERTURBATEUR varchar(10)\n        MED_MED_PERTURBE varchar(10)\n    }\n\n    class posseder {\n        PRA_NUM smallint\n        SPE_CODE varchar(5)\n        POS_DIPLOME varchar(10)\n        POS_COEFPRESCRIPTION float\n    }\n\n    class specialite {\n        SPE_CODE varchar(5)\n        SPE_LIBELLE varchar(150)\n    }\n\n    class employes {\n        id int\n        matricule varchar(50)\n        nom varchar(100)\n        prenom varchar(100)\n        adresse varchar(255)\n        code_postal varchar(10)\n        ville varchar(100)\n        date_embauche date\n        &lt;&lt;PK&gt;&gt; id\n        &lt;&lt;Unique&gt;&gt; matricule\n    }\n    \n    class switchboard_items {\n        SwitchboardID int\n        ItemNumber smallint\n        ItemText varchar(255)\n        Command smallint\n        Argument varchar(255)\n    }\n    \n    %% Relations des tables d&#39;association (clé composée)\n    \n    activite_compl \&quot;1\&quot; -- \&quot;*\&quot; inviter : (AC_NUM)\n    praticien \&quot;1\&quot; -- \&quot;*\&quot; inviter : (PRA_NUM)\n    \n    activite_compl \&quot;1\&quot; -- \&quot;*\&quot; realiser : (AC_NUM)\n    visiteur \&quot;1\&quot; -- \&quot;*\&quot; realiser : (VIS_MATRICULE)\n    \n    visiteur \&quot;1\&quot; -- \&quot;*\&quot; rapport_visite : (VIS_MATRICULE, RAP_NUM)\n    praticien \&quot;1\&quot; -- \&quot;*\&quot; rapport_visite : (PRA_NUM)\n    \n    rapport_visite \&quot;1\&quot; -- \&quot;*\&quot; offrir : (VIS_MATRICULE, RAP_NUM)\n    medicament \&quot;1\&quot; -- \&quot;*\&quot; offrir : (MED_DEPOTLEGAL)\n\n    praticien \&quot;1\&quot; -- \&quot;*\&quot; posseder : (PRA_NUM)\n    specialite \&quot;1\&quot; -- \&quot;*\&quot; posseder : (SPE_CODE)\n\n    medicament \&quot;1\&quot; -- \&quot;*\&quot; constituer : (MED_DEPOTLEGAL)\n    composant \&quot;1\&quot; -- \&quot;*\&quot; constituer : (CMP_CODE)\n\n    medicament \&quot;1\&quot; -- \&quot;*\&quot; prescrire : (MED_DEPOTLEGAL)\n    type_individu \&quot;1\&quot; -- \&quot;*\&quot; prescrire : (TIN_CODE)\n    dosage \&quot;1\&quot; -- \&quot;*\&quot; prescrire : (DOS_CODE)\n\n    medicament \&quot;1\&quot; -- \&quot;*\&quot; formuler : (MED_DEPOTLEGAL)\n    presentation \&quot;1\&quot; -- \&quot;*\&quot; formuler : (PRE_CODE)\n\n    medicament \&quot;1\&quot; -- \&quot;*\&quot; interagir : (MED_PERTURBATEUR)\n    medicament \&quot;1\&quot; -- \&quot;*\&quot; interagir : (MED_MED_PERTURBE)\n    \n    visiteur \&quot;1\&quot; -- \&quot;*\&quot; travailler : (VIS_MATRICULE)\n    region \&quot;1\&quot; -- \&quot;*\&quot; travailler : (REG_CODE)\n    \n    %% Relations des clés étrangères simples\n\n    praticien \&quot;1\&quot; -- \&quot;*\&quot; type_praticien : (TYP_CODE)\n    \n    visiteur \&quot;0..1\&quot; -- \&quot;*\&quot; secteur : (SEC_CODE)\n    visiteur \&quot;0..1\&quot; -- \&quot;*\&quot; labo : (LAB_CODE)\n    \n    region \&quot;1\&quot; -- \&quot;*\&quot; secteur : (SEC_CODE)\n\n    medicament \&quot;1\&quot; -- \&quot;*\&quot; famille : (FAM_CODE)\n\n    %% L&#39;employes semble être une table séparée pour l&#39;administration, distincte de visiteur, sans clé étrangère apparente dans ce schéma.\n\n    %% Notes:\n    %% - Les tables employes et switchboard_items sont incluses mais sans relations identifiées avec le reste du schéma.\n    %% - Les relations des tables d&#39;association (e.g., offrir, inviter) sont basées sur les colonnes en double, même sans la déclaration explicite de FOREIGN KEY dans le script SQL.&quot;&#xa;}" id="2">
